# ─── Compiled Output ──────────────────────────────────────────────
target/
out/
*.class

# ─── Maven ────────────────────────────────────────────────────────
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# ─── JAR / EXE Artifacts ──────────────────────────────────────────
# Root MazeBank.exe IS committed — it's the pre-built release binary with the
# bundled demo database. Only the build-output copy in target/ is ignored.
target/*.exe
target/*.jar
*.jar
!MazeBank.exe

# ─── Database Files ───────────────────────────────────────────────
# Root bank.db IS committed — it's the anonymized demo database.
# The bundled copy inside src/resources/ is also tracked.
# Only intermediate or personal databases elsewhere are ignored.
*.sqlite
*.sqbpro

# ─── IDE / Editor ─────────────────────────────────────────────────
.idea/
*.iml
*.ipr
*.iws
.vscode/
*.code-workspace
.settings/
.classpath
.project
.factorypath
nbproject/
nb-configuration.xml

# ─── OS Artifacts ─────────────────────────────────────────────────
Thumbs.db
.DS_Store
._*
.AppleDouble
.LSOverride
desktop.ini

# ─── Logs & Temp ──────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.swp
*~
hs_err_pid*
replay_pid*
